# Normalize all text files to LF in the repo; Windows checkout is allowed to
# convert to CRLF but the canonical form stored in git is always LF.
* text=auto eol=lf

# Bash / shell (explicit, belt-and-suspenders)
*.sh        text eol=lf
*.tmpl      text eol=lf
*.env       text eol=lf
*.service   text eol=lf

# Web / Node.js source (setup-app)
*.ts        text eol=lf
*.tsx       text eol=lf
*.mts       text eol=lf
*.js        text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf
*.jsx       text eol=lf
*.json      text eol=lf
*.css       text eol=lf
*.html      text eol=lf
*.md        text eol=lf
*.mdx       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.toml      text eol=lf

# Binary — never mangle
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.woff      binary
*.woff2     binary
*.eot       binary
*.ttf       binary
*.otf       binary
*.lock      text eol=lf
