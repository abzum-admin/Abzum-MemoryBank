    "clsx": "^2.1.1",
    "dockerode": "^4.0.3",
    "drizzle-orm": "^0.38.0",
    "jose": "^5.9.6",
    "js-yaml": "^4.1.0",
    "libsodium-wrappers": "^0.7.15",
    "lucide-react": "^0.468.0",
    "next": "15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.0",
    "tailwind-merge": "^2.5.5",
    "zod": "^3.24.1"
