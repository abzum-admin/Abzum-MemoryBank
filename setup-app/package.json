{
  "name": "abzum-setup-app",
  "version": "0.1.0",
  "private": true,
  "description": "Browser UI for deploying Abzum infrastructure modules on a VPS (Hermes, cloudflared, paperclip, multica.ai)",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
