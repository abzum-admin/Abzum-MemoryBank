# Hermes — Personal Assistant
# Template rendered by scripts/deploy-service.sh.
# Markers @@INSTANCE@@ and @@INSTANCE_UI@@ are replaced at deploy time.
# Env var names listed under `environment:` are pulled from the shell env
# that `doppler run --` provides (see operations/doppler.md).
services:
  @@INSTANCE@@:
    image: nousresearch/hermes-agent:latest
    container_name: @@INSTANCE@@
    restart: unless-stopped
    command: gateway run
    shm_size: '1g'
    environment:
      - PATH=/opt/hermes/.venv/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
@@DOPPLER_ENV_LINES@@
    volumes:
      - @@INSTANCE@@-data:/opt/data
    networks:
      - proxy

  @@INSTANCE_UI@@:
    image: nousresearch/hermes-agent:latest
    container_name: @@INSTANCE_UI@@
    restart: unless-stopped
    command: dashboard --host 0.0.0.0 --no-open --port 9119
    environment:
      - PATH=/opt/hermes/.venv/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
    volumes:
      - @@INSTANCE@@-data:/opt/data
    networks:
      - proxy
    depends_on:
      - @@INSTANCE@@

volumes:
  @@INSTANCE@@-data:

networks:
  proxy:
    external: true
